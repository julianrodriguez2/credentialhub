APP_NAME=CredentialHub API
DATABASE_URL=postgresql+psycopg://credentialhub:credentialhub@postgres:5432/credentialhub
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000
STORAGE_PROVIDER=s3
S3_ENDPOINT_URL=http://localhost:9000
